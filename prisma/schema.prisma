generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================================================
// AUTH.JS V5 MODELS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("free") // free | dd_basic | dd_premium | ff_basic | ff_premium | admin
  isPaid        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile extensions
  username           String?  @unique
  bio                String?  @db.Text
  avatar             String?
  steadfastStatement String?  @db.Text
  publicProfile      Boolean  @default(false)
  stripeCustomerId   String?  @unique
  stripeSubscriptionId String?

  // Existing relations
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  conversations CompanionConversation[]
  progress      PracticeProgress[]
  reflections   WeeklyReflection[]
  hungerTests   HungerTestSession[]
  armory        ArmoryGeneration[]
  dispatches    DailyDispatch[]

  // Hearth relations
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  savedPosts       SavedPost[]
  badges           UserBadge[]
  moralTimeEntries MoralTimeEntry[]
  following        HearthFollow[] @relation("follower")
  followers        HearthFollow[] @relation("following")

  // Guided Forge
  wizardProgress   WizardProgress[]

  // Provision
  purchases        Purchase[]

  // Community moderation
  hearthVowAccepted Boolean   @default(false)
  stoicMentor       String    @default("marcus_aurelius")
  suspendedUntil    DateTime?
  bannedAt          DateTime?
  reports           Report[]  @relation("ReportedBy")

  // ePub milestone reward
  epubUnlocked      Boolean   @default(false)
  epubSentAt        DateTime?

  // Email preferences
  emailHighlights   Boolean   @default(true)

  // Email blast history
  emailBlastsSent   EmailBlastRecipient[]

  // Discreet Dynasties relations
  ddFateAudits       DDFateAudit[]
  ddPrepEvaluations  DDPrepEvaluation[]
  ddStabilityPlan    DDStabilityPlan?
  ddPathways         DDPathwayProgress[]
  ddLongTable        DDLongTableProgress?
  ddVow              DDVow?
  ddArmory           DDArmoryGeneration[]
  ddConversations    DDConversation[]
  ddHallPosts        DDHallPost[]
  ddHallComments     DDHallComment[]
  ddHallLikes        DDHallLike[]

  // Gift access
  ddAccessExpiresAt  DateTime?
  ddGiftCodes        DDGiftCode[] @relation("RedeemedCodes")
  ddGiftsSent        DDGiftCode[] @relation("GrantedCodes")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// USER PROFILE
// ============================================================================

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  householdSize  Int      @default(1)
  ages           String[] @default([])
  locationRisk   String?  // e.g. "hurricane zone", "earthquake zone", "urban", "rural"
  stabilityLevel String   @default("NOT_STARTED") // NOT_STARTED | STABILITY | CONTINUITY | INTEGRITY
  currentWeek    Int      @default(1)
  dietaryNeeds        String?
  medicalNeeds        String?
  practiceTrack       String   @default("foundation")  // foundation | stewardship
  stewardshipLevel    String   @default("MY_HEARTH")   // MY_HEARTH | MARGIN | NEIGHBOR_READINESS | SECOND_HEARTH | LEGACY_CIRCLE
  stewardshipOptInAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// BOOK CONTENT + RAG
// ============================================================================

model BookContent {
  id         String   @id @default(cuid())
  chapter    String   // e.g. "The Hunger Test", "Foreword", "Introduction"
  section    String?  // e.g. "Moral Claim", "Stoic Rationale", "Practice"
  subsection String?  // e.g. paragraph heading or sub-topic
  chunkIndex Int      // ordering within the chapter/section
  text       String   @db.Text
  embedding  Unsupported("vector(1536)")?
  metadata   Json?    // { wordCount, chapterNumber, pageRange, etc. }
  createdAt  DateTime @default(now())

  @@index([chapter])
}

// ============================================================================
// STOIC COMPANION
// ============================================================================

model CompanionConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CompanionMessage[]

  @@index([userId])
}

model CompanionMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String   @db.Text
  ragChunkIds    String[] @default([])
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation CompanionConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ============================================================================
// PRACTICE OS
// ============================================================================

model PracticeProgress {
  id               String   @id @default(cuid())
  userId           String
  week             Int      // 1-15
  status           String   @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED | SKIPPED
  completedActions String[] @default([])
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, week])
}

model WeeklyReflection {
  id        String   @id @default(cuid())
  userId    String
  week      Int
  content   String   @db.Text
  mood      String?  // calm | steady | strained | uncertain | resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, week])
}

// ============================================================================
// VIRTUE SIMULATOR (HUNGER TEST SCENARIOS)
// ============================================================================

model HungerTestSession {
  id           String   @id @default(cuid())
  userId       String
  scenarioSeed String   @db.Text // The AI-generated scenario premise
  virtueScores Json?    // { prudence: 0-10, courage: 0-10, temperance: 0-10, justice: 0-10 }
  status       String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  choices HungerTestChoice[]

  @@index([userId])
}

model HungerTestChoice {
  id         String   @id @default(cuid())
  sessionId  String
  round      Int      // 1, 2, 3...
  situation  String   @db.Text
  options    Json     // Array of { text, virtueAlignment }
  chosenIdx  Int?
  reflection String?  @db.Text // AI-generated feedback after choice
  createdAt  DateTime @default(now())

  session HungerTestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ============================================================================
// ARMORY GENERATIONS
// ============================================================================

model ArmoryGeneration {
  id               String   @id @default(cuid())
  userId           String
  templateType     String   // "stability-plan" | "two-family-checklist" | "provisioning-calc" | "custom"
  title            String?
  userInputs       Json?    // The user-provided context for generation
  generatedContent String   @db.Text
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// DAILY DISPATCH
// ============================================================================

model DailyDispatch {
  id         String    @id @default(cuid())
  userId     String
  date       DateTime  @db.Date
  subject    String
  content    String    @db.Text
  chapterRef String?   // Which chapter this references
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ============================================================================
// ECOSYSTEM WAITLIST
// ============================================================================

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String
  name      String?
  interest  String   // "discreet-dynasties" | "forging-fathers"
  createdAt DateTime @default(now())

  @@unique([email, interest])
}

// ============================================================================
// THE HEARTH — SOCIAL LAYER
// ============================================================================

model Post {
  id           String    @id @default(cuid())
  authorId     String
  content      String    @db.Text
  imageUrl     String?
  category     String?   // "hunger-test" | "two-family" | "moral-time" | "household-audit" | "general"
  isReflection Boolean   @default(false)
  isPinned     Boolean   @default(false)
  isFlagged    Boolean   @default(false)
  flagReason   String?
  tierRequired String?   // null = public, "dd_basic" | "ff_basic" etc.
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]
  savedBy  SavedPost[]

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
  @@index([tierRequired])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String   @db.Text
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentThread")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model SavedPost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model HearthFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================================================
// RESOURCES LIBRARY
// ============================================================================

model ResourceCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  sortOrder   Int        @default(0)
  resources   Resource[]
}

model Resource {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  type          String   // "pdf" | "checklist" | "spreadsheet" | "audio" | "video"
  fileUrl       String?
  content       String?  @db.Text
  tierRequired  String?  // null = free
  categoryId    String?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ResourceCategory? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([tierRequired])
}

// ============================================================================
// GAMIFICATION
// ============================================================================

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String
  iconUrl     String?
  criteria    Json?
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model MoralTimeEntry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  action     String   @db.Text
  reflection String?  @db.Text
  score      Int?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ============================================================================
// STRIPE SUBSCRIPTIONS
// ============================================================================

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  stripeSubscriptionId   String   @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  status                 String   // "active" | "canceled" | "past_due" | "trialing"
  tier                   String   // "dd_basic" | "dd_premium" | "ff_basic" | "ff_premium"
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// ============================================================================
// DISPATCHES — AUTHOR BLOG
// ============================================================================

model Dispatch {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String    @db.Text
  content       String    @db.Text // Markdown
  coverImageUrl String?
  tags          String[]  @default([])
  published     Boolean   @default(false)
  publishedAt   DateTime?
  tierRequired  String?
  hearthPostId  String?
  readingTime   Int       @default(5)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
}

// ============================================================================
// PODCAST
// ============================================================================

model PodcastEpisode {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  episodeNumber Int       @unique
  description   String    @db.Text
  showNotes     String?   @db.Text // Markdown
  transcript    String?   @db.Text
  audioUrl      String
  artworkUrl    String?
  duration      Int? // seconds
  fileSize      Int? // bytes
  chapters      Json? // [{title, startTime}]
  published     Boolean   @default(false)
  publishedAt   DateTime?
  tierRequired  String?
  hearthPostId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
}

// ============================================================================
// GUIDED FORGE — WIZARD SYSTEM
// ============================================================================

model WizardProgress {
  id          String    @id @default(cuid())
  userId      String
  wizardSlug  String
  version     Int       @default(1)
  stepData    Json      @default("{}")
  currentStep Int       @default(0)
  status      String    @default("in_progress") // in_progress | completed
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exports WizardExport[]

  @@unique([userId, wizardSlug, version])
  @@index([userId])
}

model WizardExport {
  id         String   @id @default(cuid())
  progressId String
  format     String   // "pdf" | "markdown"
  fileUrl    String?
  content    String?  @db.Text
  createdAt  DateTime @default(now())

  progress WizardProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
}

// ============================================================================
// THE PROVISION — SHOP
// ============================================================================

model Product {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String    @db.Text
  details       String?   @db.Text       // Markdown (long description)
  price         Int                       // cents
  comparePrice  Int?                      // cents (for "was $X" display)
  imageUrl      String?
  images        String[]  @default([])    // gallery
  category      String                    // digital, physical, plan, kit, edc, woodworking, workbook
  tags          String[]  @default([])
  downloadUrl   String?                   // for digital products
  inventory     Int?                      // null = unlimited
  published     Boolean   @default(false)
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  purchases     Purchase[]

  @@index([published, category])
  @@index([slug])
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  stripeSessionId String   @unique
  amount          Int                // cents paid
  status          String   @default("completed") // completed, refunded
  shippingName    String?
  shippingAddress Json?
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
}

// ============================================================================
// HEARTH MODERATION
// ============================================================================

model Report {
  id         String    @id @default(cuid())
  reporterId String
  targetType String    // "post" | "comment"
  targetId   String
  reason     String    // "remain-good" | "steward-circle" | "honor-moral-time" | "privacy" | "commercial" | "spam" | "other"
  notes      String?   @db.Text
  status     String    @default("pending") // pending | resolved | dismissed
  aiFlag     Boolean   @default(false)
  aiReason   String?   @db.Text
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  reporter User @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
}

model ModerationAction {
  id              String   @id @default(cuid())
  adminId         String
  targetUserId    String
  targetPostId    String?
  targetCommentId String?
  action          String   // "reminder" | "delete" | "suspend" | "ban"
  privateNote     String?  @db.Text
  publicNote      String?  @db.Text
  suspendDays     Int?
  createdAt       DateTime @default(now())

  @@index([targetUserId])
  @@index([createdAt])
}

// ============================================================================
// EMAIL BLASTS
// ============================================================================

model EmailBlast {
  id           String   @id @default(cuid())
  adminId      String
  subject      String
  body         String   @db.Text  // HTML
  segment      String   // "all" | "free" | "dd" | "ff" | "paid" | "week5plus" | "highlights"
  recipientCount Int    @default(0)
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  recipients EmailBlastRecipient[]

  @@index([sentAt])
}

model EmailBlastRecipient {
  id        String   @id @default(cuid())
  blastId   String
  userId    String
  email     String
  status    String   @default("sent") // sent | bounced | failed
  createdAt DateTime @default(now())

  blast EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blastId])
  @@index([userId])
}

// ============================================================================
// DISCREET DYNASTIES — DD-PREFIXED MODELS
// ============================================================================

model DDBookContent {
  id           String   @id @default(cuid())
  part         Int
  chapter      Int
  chapterTitle String
  section      String?
  chunkIndex   Int
  text         String   @db.Text
  embedding    Unsupported("vector(1536)")?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([chapter])
  @@index([part])
}

model DDFateAudit {
  id            String   @id @default(cuid())
  userId        String
  takenAt       DateTime @default(now())
  householdSize Int      @default(1)
  propertyType  String?
  climateZone   String?

  foodStability       Int @default(0)
  foodContinuity      Int @default(0)
  foodIntegrity       Int @default(0)
  assuranceStability  Int @default(0)
  assuranceContinuity Int @default(0)
  assuranceIntegrity  Int @default(0)
  toolsStability      Int @default(0)
  toolsContinuity     Int @default(0)
  toolsIntegrity      Int @default(0)
  energyStability     Int @default(0)
  energyContinuity    Int @default(0)
  energyIntegrity     Int @default(0)

  notes        String? @db.Text
  aiActionPlan String? @db.Text
  rawAnswers   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DDPrepEvaluation {
  id             String   @id @default(cuid())
  userId         String
  prepName       String
  domain         String
  description    String   @db.Text
  classification String
  aiAnalysis     String   @db.Text
  conversionPlan String?  @db.Text
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DDStabilityPlan {
  id              String   @id @default(cuid())
  userId          String   @unique
  hungerPlan      String   @db.Text
  waterPlan       String   @db.Text
  powerPlan       String   @db.Text
  medicalPlan     String   @db.Text
  cashPlan        String   @db.Text
  givingThreshold String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DDPathwayProgress {
  id          String    @id @default(cuid())
  userId      String
  pathway     String
  weekNumber  Int       @default(1)
  status      String    @default("in_progress")
  weekData    Json      @default("{}")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathway])
  @@index([userId])
}

model DDLongTableProgress {
  id               String   @id @default(cuid())
  userId           String   @unique
  level            Int      @default(1)
  notes            String?  @db.Text
  keyRelationships Json     @default("[]")
  civicPositions   Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DDVow {
  id          String   @id @default(cuid())
  userId      String   @unique
  takenAt     DateTime @default(now())
  displayName String?
  state       String?
  isPublic    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DDArmoryGeneration {
  id               String   @id @default(cuid())
  userId           String
  generatorType    String
  title            String?
  userInputs       Json?
  generatedContent String   @db.Text
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DDConversation {
  id        String   @id @default(cuid())
  userId    String
  advisor   String   @default("steward")
  title     String   @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages DDMessage[]

  @@index([userId])
}

model DDMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  ragChunkIds    String[] @default([])
  createdAt      DateTime @default(now())

  conversation DDConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model DDHallPost {
  id           String    @id @default(cuid())
  authorId     String
  content      String    @db.Text
  category     String    @default("general")
  skillCircle  String?
  isPinned     Boolean   @default(false)
  isFlagged    Boolean   @default(false)
  isJournal    Boolean   @default(false)
  tierRequired String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments DDHallComment[]
  likes    DDHallLike[]

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
}

model DDHallComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String   @db.Text
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())

  post    DDHallPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  DDHallComment? @relation("DDCommentThread", fields: [parentId], references: [id])
  replies DDHallComment[] @relation("DDCommentThread")

  @@index([postId])
  @@index([authorId])
}

model DDHallLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post DDHallPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ============================================================================
// GIFT ACCESS CODES
// ============================================================================

model DDGiftCode {
  id               String    @id @default(cuid())
  code             String    @unique
  type             String    // "1_week" | "1_month" | "3_months" | "walking_pass"
  recipientEmail   String?
  note             String?
  grantedByAdminId String
  redeemedByUserId String?
  redeemedAt       DateTime?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  grantedBy  User  @relation("GrantedCodes", fields: [grantedByAdminId], references: [id])
  redeemedBy User? @relation("RedeemedCodes", fields: [redeemedByUserId], references: [id])

  @@index([code])
  @@index([grantedByAdminId])
  @@index([redeemedByUserId])
}

// ============================================================================
// SOCIAL DISPATCH & CRON INFRASTRUCTURE
// ============================================================================

model SocialPost {
  id          String    @id @default(cuid())
  platform    String
  content     String    @db.Text
  postSlug    String
  platformId  String?
  status      String
  postedAt    DateTime?
  scheduledAt DateTime?
  threadArc   String?   @db.Text
  error       String?   @db.Text
  createdAt   DateTime  @default(now())

  metrics SocialMetric[]

  @@index([postSlug])
  @@index([status])
  @@index([createdAt])
}

model SocialMetric {
  id           String   @id @default(cuid())
  socialPostId String
  impressions  Int      @default(0)
  engagements  Int      @default(0)
  clicks       Int      @default(0)
  likes        Int      @default(0)
  retweets     Int      @default(0)
  replies      Int      @default(0)
  createdAt    DateTime @default(now())

  socialPost SocialPost @relation(fields: [socialPostId], references: [id])

  @@index([socialPostId])
}

model CronLog {
  id              String   @id @default(cuid())
  cronName        String
  status          String   @default("success")
  durationMs      Int      @default(0)
  recordsAffected Int      @default(0)
  phases          String?
  errors          String?
  gitSHA          String?
  executedAt      DateTime @default(now())

  @@index([cronName])
  @@index([executedAt])
  @@index([status])
}

model EvergreenCursor {
  id              String   @id @default(cuid())
  currentPostSlug String
  currentLine     Int      @default(0)
  completedPosts  String   @default("[]")
  cycleNumber     Int      @default(1)
  lastModelIndex  Int      @default(-1)
  updatedAt       DateTime @updatedAt
}

model EvergreenQuote {
  id               String    @id @default(cuid())
  postSlug         String
  startLine        Int
  endLine          Int
  extractedPassage String
  passageHash      String    @unique
  model            String
  cycleNumber      Int
  facebookCopy     String?
  xCopy            String?
  instagramCopy    String?
  dispatchStatus   String    @default("extracted")
  dispatchedAt     DateTime?
  createdAt        DateTime  @default(now())

  @@index([postSlug])
  @@index([dispatchStatus])
  @@index([createdAt])
}
